package main;
import {
    "IO",
    "Math"
}

class Player {
    var <set, get> float64 health {
        set(float64 value) {
            health = Math::clamp(value, 0.0, 100.0);
        }
        get() {
            return health;
        }
    }
    var <get> float64 dmg {
        get() {
            dmg = dmg + 5;
            return dmg;
        }
    }
}

