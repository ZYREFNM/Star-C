package IO;

class Input {
}

class Output {
    static func void print(string text) {
        C:function printf(text);
    }
    
    static func void printf(string fmt, string text) {
        C:function printf(fmt, text);
    }
    
    static func void printfln(string fmt, string text) {
        C:function printf(fmt << "\n", text);
    }
}    